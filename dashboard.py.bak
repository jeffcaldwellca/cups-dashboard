_SETTINGS_FORM = """
<div class="card">
  <div class="card-header"><h5 class="mb-0">Application Settings</h5></div>
  <div class="card-body p-0">
    <ul class="nav nav-tabs px-3 pt-2" id="settingsTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-ad" type="button">
          Active Directory
        </button>
      </li>
    </ul>
    <div class="tab-content p-4">

      <!-- AD tab -->
      <div class="tab-pane fade show active" id="tab-ad">
        {% if save_ok is defined %}
          <div class="alert alert-{{ 'success' if save_ok else 'danger' }} py-2">
            {{ save_msg }}
          </div>
        {% endif %}

        <form method="post" action="/settings">
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

          <div class="settings-section">
            <h6>Connection</h6>
            <div class="form-row">
              <label for="ad_server">Server / Host</label>
              <input id="ad_server" name="ad_server" class="form-control"
                     value="{{ cfg.server }}" placeholder="dc.example.com">
            </div>
            <div class="form-row">
              <label for="ad_port">Port</label>
              <input id="ad_port" name="ad_port" type="number" class="form-control"
                     value="{{ cfg.port }}" style="max-width:120px">
            </div>
            <div class="check-row">
              <input id="use_ssl" name="use_ssl" type="checkbox" {{ 'checked' if cfg.use_ssl }}>
              <label for="use_ssl">Use LDAPS (SSL/TLS)</label>
            </div>
            <div class="check-row">
              <input id="verify_ssl" name="verify_ssl" type="checkbox" {{ 'checked' if cfg.verify_ssl }}>
              <label for="verify_ssl">Verify SSL certificate</label>
            </div>
          </div>

          <div class="settings-section">
            <h6>Bind Credentials</h6>
            <div class="form-row">
              <label for="bind_dn">Bind DN</label>
              <input id="bind_dn" name="bind_dn" class="form-control"
                     value="{{ cfg.bind_dn }}"
                     placeholder="CN=svc-cups,OU=ServiceAccounts,DC=example,DC=com">
            </div>
            <div class="form-row">
              <label for="bind_password">Bind Password</label>
              {% if ad_bind_pw_env %}
                <input class="form-control" disabled value="(set via CUPS_AD_BIND_PASSWORD env var)">
                <input type="hidden" name="bind_password" value="">
              {% else %}
                <input id="bind_password" name="bind_password" type="password"
                       class="form-control" autocomplete="new-password"
                       placeholder="Leave blank to keep existing">
              {% endif %}
            </div>
          </div>

          <div class="settings-section">
            <h6>Directory Structure</h6>
            <div class="form-row">
              <label for="base_dn">Base DN</label>
              <input id="base_dn" name="base_dn" class="form-control"
                     value="{{ cfg.base_dn }}" placeholder="DC=example,DC=com">
            </div>
            <div class="form-row">
              <label for="user_search_base">User Search Base (optional)</label>
              <input id="user_search_base" name="user_search_base" class="form-control"
                     value="{{ cfg.user_search_base }}"
                     placeholder="OU=Users,DC=example,DC=com">
            </div>
          </div>

          <div class="settings-section">
            <h6>Attribute Mapping</h6>
            <div class="form-row">
              <label for="username_attr">Username attribute</label>
              <input id="username_attr" name="username_attr" class="form-control"
                     value="{{ cfg.username_attr }}" placeholder="sAMAccountName">
            </div>
            <div class="form-row">
              <label for="display_name_attr">Display name attribute</label>
              <input id="display_name_attr" name="display_name_attr" class="form-control"
                     value="{{ cfg.display_name_attr }}" placeholder="displayName">
            </div>
            <div class="form-row">
              <label for="email_attr">Email attribute</label>
              <input id="email_attr" name="email_attr" class="form-control"
                     value="{{ cfg.email_attr }}" placeholder="mail">
            </div>
            <div class="form-row">
              <label for="department_attr">Department attribute</label>
              <input id="department_attr" name="department_attr" class="form-control"
                     value="{{ cfg.department_attr }}" placeholder="department">
            </div>
            <div class="form-row">
              <label for="title_attr">Title attribute</label>
              <input id="title_attr" name="title_attr" class="form-control"
                     value="{{ cfg.title_attr }}" placeholder="title">
            </div>
          </div>

          <div class="settings-section">
            <h6>Cache</h6>
            <div class="form-row">
              <label for="cache_ttl_hours">Cache TTL (hours)</label>
              <input id="cache_ttl_hours" name="cache_ttl_hours" type="number"
                     class="form-control" value="{{ cfg.cache_ttl_hours }}"
                     style="max-width:120px" min="1" max="720">
            </div>
          </div>

          <div class="settings-section">
            <h6>Enable</h6>
            <div class="check-row">
              <input id="ad_enabled" name="ad_enabled" type="checkbox"
                     {{ 'checked' if cfg.enabled }}>
              <label for="ad_enabled">Enable Active Directory enrichment</label>
            </div>
          </div>

          <div style="display:flex;gap:.75rem;margin-top:1.5rem;align-items:center">
            <button type="submit" class="btn btn-primary">Save Settings</button>
            <button type="button" class="btn btn-secondary" id="btn-test-ad">
              Test Connection
            </button>
            <button type="button" class="btn btn-secondary" id="btn-sync-ad">
              Sync AD Users
            </button>
            <span id="ad-result" style="font-size:.875rem"></span>
          </div>
        </form>
      </div><!-- /tab-ad -->

    </div><!-- /tab-content -->
  </div><!-- /card-body -->
</div>

<script>
(function(){
  var csrf = document.querySelector('[name=csrf_token]').value;

  function postJSON(url, cb) {
    fetch(url, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({csrf_token: csrf})
    })
    .then(function(r){ return r.json(); })
    .then(cb)
    .catch(function(e){ cb({success: false, message: String(e)}); });
  }

  document.getElementById('btn-test-ad').addEventListener('click', function(){
    var el = document.getElementById('ad-result');
    el.textContent = 'Testing…';
    postJSON('/settings/test-ad', function(d){
      el.style.color = d.success ? '#198754' : '#dc3545';
      el.textContent = d.message;
    });
  });

  document.getElementById('btn-sync-ad').addEventListener('click', function(){
    var el = document.getElementById('ad-result');
    el.textContent = 'Syncing…';
    postJSON('/settings/sync-ad', function(d){
      el.style.color = d.success ? '#198754' : '#dc3545';
      el.textContent = d.message;
    });
  });
})();
</script>
"""


@app.route("/settings", methods=["GET", "POST"])
def settings_page():
    save_ok = None
    save_msg = ""
    cfg = get_ad_config()
    ad_cfg = cfg  # alias used by render_page context

    if request.method == "POST":
        if not _verify_csrf():
            return render_page("<p class='alert alert-danger'>Invalid CSRF token.</p>",
                               "Settings", status=400)

        # Build new config dict from form
        new_cfg = {
            "enabled":           "ad_enabled"       in request.form,
            "server":            request.form.get("ad_server",          "").strip(),
            "port":              int(request.form.get("ad_port",        389) or 389),
            "use_ssl":           "use_ssl"           in request.form,
            "verify_ssl":        "verify_ssl"        in request.form,
            "auth_method":       "simple",
            "bind_dn":           request.form.get("bind_dn",            "").strip(),
            "base_dn":           request.form.get("base_dn",            "").strip(),
            "user_search_base":  request.form.get("user_search_base",   "").strip(),
            "username_attr":     request.form.get("username_attr",      "sAMAccountName").strip(),
            "display_name_attr": request.form.get("display_name_attr",  "displayName").strip(),
            "email_attr":        request.form.get("email_attr",         "mail").strip(),
            "department_attr":   request.form.get("department_attr",    "department").strip(),
            "title_attr":        request.form.get("title_attr",         "title").strip(),
            "cache_ttl_hours":   int(request.form.get("cache_ttl_hours", 24) or 24),
        }

        # Password: only update if provided and not overridden by env var
        pw = request.form.get("bind_password", "").strip()
        env_pw = os.environ.get("CUPS_AD_BIND_PASSWORD", "")
        if env_pw:
            new_cfg["bind_password"] = env_pw
        elif pw:
            new_cfg["bind_password"] = pw
        else:
            # Keep existing password
            new_cfg["bind_password"] = cfg.get("bind_password", "")

        try:
            set_config("ad_config", json.dumps(new_cfg))
            save_ok = True
            save_msg = "Settings saved successfully."
            cfg = new_cfg
        except Exception as exc:
            save_ok = False
            save_msg = f"Error saving settings: {exc}"

    from jinja2 import Template as _Template  # local import to avoid circular
    tmpl = _Template(_SETTINGS_FORM)
    body = tmpl.render(
        cfg=cfg,
        csrf_token=_csrf_token(),
        ad_bind_pw_env=bool(os.environ.get("CUPS_AD_BIND_PASSWORD")),
        save_ok=save_ok,
        save_msg=save_msg,
    )
    return render_page(body, "Settings")


@app.route("/settings/test-ad", methods=["POST"])
def test_ad_route():
    data = request.get_json(silent=True) or {}
    if not secrets.compare_digest(str(data.get("csrf_token", "")),
                                   str(session.get("csrf_token", ""))):
        return jsonify({"success": False, "message": "Invalid CSRF token."}), 403
    cfg = get_ad_config()
    ok, msg = test_ad_connection(cfg)
    return jsonify({"success": ok, "message": msg})


@app.route("/settings/sync-ad", methods=["POST"])
def sync_ad_route():
    data = request.get_json(silent=True) or {}
    if not secrets.compare_digest(str(data.get("csrf_token", "")),
                                   str(session.get("csrf_token", ""))):
        return jsonify({"success": False, "message": "Invalid CSRF token."}), 403
    try:
        with closing(get_db()) as conn:
            users = [
                r["user_name"]
                for r in conn.execute(
                    "SELECT DISTINCT user_name FROM jobs WHERE user_name IS NOT NULL"
                ).fetchall()
            ]
        enrich_users_from_ad(users)
        return jsonify({"success": True,
                        "message": f"Sync triggered for {len(users)} users."})
    except Exception as exc:
        return jsonify({"success": False, "message": str(exc)})


# ─── Error handlers ───────────────────────────────────────────────────────────

@app.errorhandler(404)
def page_not_found(e):
    body = "<div class='alert alert-warning'><strong>404</strong> — Page not found.</div>"
    return render_page(body, "Not Found", status=404)


@app.errorhandler(500)
def internal_error(e):
    body = "<div class='alert alert-danger'><strong>500</strong> — Internal server error.</div>"
    return render_page(body, "Server Error", status=500)


