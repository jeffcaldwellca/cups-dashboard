if __name__ == "__main__":
    STARTUP_INIT_DONE = False
    init_db()
    if Path(PAGE_LOG_PATH).exists():
        with _IMPORT_LOCK:
            import_page_log_incremental()
    _start_bg_refresh()
    STARTUP_INIT_DONE = True
    app.run(host=HOST, port=PORT, debug=DEBUG)
